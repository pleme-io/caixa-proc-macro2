   :body "[package]\nname = \"proc-macro2-ui-test\"\nversion = \"0.0.0\"\nauthors = [\"David Tolnay <dtolnay@gmail.com>\"]\nedition = \"2021\"\npublish = false\n\n[[test]]\nname = \"compiletest\"\npath = \"compiletest.rs\"\n\n[dev-dependencies]\nproc-macro2 = { path = \"../..\" }\nrustversion = \"1.0\"\ntrybuild = { version = \"1.0.108\", features = [\"diff\"] }\n"} {:path "tests/ui/compiletest.rs"
