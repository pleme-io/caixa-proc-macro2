   :body "#![allow(dead_code)]\n\n#[cfg(proc_macro_span)]\npub(crate) mod proc_macro_span;\n\n#[cfg(proc_macro_span_file)]\npub(crate) mod proc_macro_span_file;\n\n#[cfg(proc_macro_span_location)]\npub(crate) mod proc_macro_span_location;\n"} {:path "src/rcvec.rs"
