   :body "#![allow(clippy::assertions_on_constants, clippy::ignore_without_reason)]\n\n#[test]\n#[ignore]\nfn make_sure_no_proc_macro() {\n    assert!(\n        !cfg!(feature = \"proc-macro\"),\n        \"still compiled with proc_macro?\"\n    );\n}\n"} {:path "tests/ui/Cargo.toml"
